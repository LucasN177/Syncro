@page "/calendar"
@using Syncro.Core.Models
@using Syncro.Layout.Helper
@using Syncro.Layout.UI_Models
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.False" Class="pa-6" Style="min-height: 100vh; background: #F8FAFC;">
    
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -1px;">Calendar</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @_currentMonth.ToString("MMMM yyyy") · @_events.Count(e => e.Start.Month == _currentMonth.Month) events this month
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 10px; overflow: hidden;">
                <MudButton OnClick="PrevMonth" Style="font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small" />
                </MudButton>
                <MudButton OnClick="GoToToday" Style="font-weight: 700;">Today</MudButton>
                <MudButton OnClick="NextMonth" Style="font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                </MudButton>
            </MudButtonGroup>

            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 10px; overflow: hidden;">
                @foreach (var view in new[] { "Month", "Week", "List" })
                {
                    <MudButton OnClick="@(() => _activeView = view)"
                               Style="@(_activeView == view ? "font-weight:700; background: var(--mud-palette-primary); color: #fff;" : "font-weight:600;")">
                        @view
                    </MudButton>
                }
            </MudButtonGroup>

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Size="Size.Small"
                       Style="border-radius: 10px; font-weight: 700;"
                       OnClick="OpenAddDialog">
                Add Event
            </MudButton>
        </MudStack>
    </MudStack>
    
    <MudStack Row="true" Spacing="2" Class="mb-5" Style="flex-wrap: wrap;">
        @foreach (var cat in _categories)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="@(cat.Active ? Variant.Filled : Variant.Outlined)"
                     Color="@cat.Color"
                     OnClick="@(() => ToggleCategory(cat))"
                     Style="font-weight: 600; border-radius: 8px; cursor: pointer;">
                @cat.Name (@_events.Count(e => e.Category == cat.Name))
            </MudChip>
        }
    </MudStack>
    
    @if (_activeView == "Month")
    {
        <MudPaper Elevation="0" Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); overflow: hidden; background: #fff;">
            
            <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider); background: #F8FAFC;">
                @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                {
                    <MudItem xs="0" Style="width: calc(100% / 7);">
                        <MudText Typo="Typo.caption" Align="Align.Center"
                                 Style="font-weight: 700; letter-spacing: 0.08em; padding: 12px 0; display: block; color: var(--mud-palette-text-secondary);">
                            @day
                        </MudText>
                    </MudItem>
                }
            </MudGrid>
            
            @{
                var weeks = CalendarHelper.GetCalendarWeeks();
            }
            @foreach (var week in weeks)
            {
                <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                    @foreach (var day in week)
                    {
                        var dayEvents = CalendarHelper.GetEventsForDay(day, _events);
                        var isToday = day.Date == DateTime.Today;
                        var isCurrentMonth = day.Month == _currentMonth.Month;
                        var isSelected = _selectedDay.HasValue && _selectedDay.Value.Date == day.Date;

                        <MudItem Style="width: calc(100% / 7); min-height: 110px; border-right: 1px solid var(--mud-palette-divider); padding: 8px; cursor: pointer; transition: background 0.15s;"
                                 @onclick="@(() => SelectDay(day))">
                            
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                @if (isToday)
                                {
                                    <MudAvatar Size="Size.Small" Color="Color.Primary"
                                               Style="width: 26px; height: 26px; font-size: 0.75rem; font-weight: 800;">
                                        @day.Day
                                    </MudAvatar>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2"
                                             Style="@($"font-weight: {(isCurrentMonth ? "600" : "400")}; color: {(isCurrentMonth ? "inherit" : "var(--mud-palette-text-disabled)")};")">
                                        @day.Day
                                    </MudText>
                                }
                            </MudStack>
                            
                            @foreach (var ev in dayEvents.Take(3))
                            {
                                var cat = _categories.FirstOrDefault(c => c.Name == ev.Category);
                                @if (cat?.Active == true)
                                {
                                    <MudTooltip Text="@($"{ev.Title} · {ev.Start:HH:mm}")">
                                        <MudPaper Elevation="0" Class="mb-1 px-1"
                                                  Style="@($"border-radius: 4px; background: {cat.Hex}22; border-left: 3px solid {cat.Hex}; cursor: pointer;")"
                                                  @onclick="@(() => OpenEventDetail(ev))">
                                            <MudText Style="@($"font-size: 0.68rem; font-weight: 600; color: {cat.Hex}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.8;")">
                                                @ev.Title
                                            </MudText>
                                        </MudPaper>
                                    </MudTooltip>
                                }
                            }
                            @if (dayEvents.Count > 3)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                         Style="font-size: 0.65rem; font-weight: 600;">
                                    +@(dayEvents.Count - 3) more
                                </MudText>
                            }

                        </MudItem>
                    }
                </MudGrid>
            }

        </MudPaper>
    }
    
    @if (_activeView == "Week")
    {
        var weekDays = CalendarHelper.GetCurrentWeekDays(_selectedDay);

        <MudPaper Elevation="0" Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); overflow: hidden; background: #fff;">
            
            <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider); background: #F8FAFC;">
                <MudItem Style="width: 60px; min-width: 60px;" />
                @foreach (var day in weekDays)
                {
                    var isToday = day.Date == DateTime.Today;
                    <MudItem Style="flex: 1; text-align: center; padding: 12px 4px;">
                        <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.05em; color: var(--mud-palette-text-secondary); display: block;">
                            @day.ToString("ddd").ToUpper()
                        </MudText>
                        @if (isToday)
                        {
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Style="width: 28px; height: 28px; font-size: 0.8rem; font-weight: 800; margin: 2px auto 0;">
                                @day.Day
                            </MudAvatar>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1" Style="font-weight: 700;">@day.Day</MudText>
                        }
                    </MudItem>
                }
            </MudGrid>
            
            <div style="max-height: 520px; overflow-y: auto;">
                @for (int h = 7; h <= 20; h++)
                {
                    var hour = h;
                    <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider); min-height: 56px;">
                        <MudItem Style="width: 60px; min-width: 60px; padding: 6px 8px; border-right: 1px solid var(--mud-palette-divider);">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem; font-weight: 600;">
                                @($"{hour:D2}:00")
                            </MudText>
                        </MudItem>
                        @foreach (var day in weekDays)
                        {
                            var slotEvents = _events.Where(e =>
                                e.Start.Date == day.Date &&
                                e.Start.Hour == hour &&
                                (_categories.FirstOrDefault(c => c.Name == e.Category)?.Active ?? true)).ToList();

                            <MudItem Style="flex: 1; padding: 3px; border-right: 1px solid var(--mud-palette-divider); cursor: pointer;"
                                     @onclick="@(() => SelectDay(day))">
                                @foreach (var ev in slotEvents)
                                {
                                    var cat = _categories.FirstOrDefault(c => c.Name == ev.Category);
                                    <MudTooltip Text="@ev.Description">
                                        <MudPaper Elevation="0" Class="px-2 py-1 mb-1"
                                                  Style="@($"border-radius: 6px; background: {cat?.Hex}22; border-left: 3px solid {cat?.Hex}; cursor: pointer;")"
                                                  @onclick="@(() => OpenEventDetail(ev))">
                                            <MudText Style="@($"font-size: 0.68rem; font-weight: 700; color: {cat?.Hex};")">@ev.Title</MudText>
                                            <MudText Style="font-size: 0.62rem; color: var(--mud-palette-text-secondary);">@ev.Start.ToString("HH:mm")</MudText>
                                        </MudPaper>
                                    </MudTooltip>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                }
            </div>
        </MudPaper>
    }
    
    @if (_activeView == "List")
    {
        var grouped = _events
            .Where(e => e.Start >= DateTime.Today && (_categories.FirstOrDefault(c => c.Name == e.Category)?.Active ?? true))
            .OrderBy(e => e.Start)
            .GroupBy(e => e.Start.Date)
            .Take(14)
            .ToList();

        <MudStack Spacing="4">
            @foreach (var group in grouped)
            {
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (group.Key.Date == DateTime.Today)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                     Style="font-weight: 700; border-radius: 8px;">Today</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: var(--mud-palette-text-secondary);">
                                @group.Key.ToString("dddd, MMM d")
                            </MudText>
                        }
                        <MudDivider Style="flex: 1;" />
                    </MudStack>

                    @foreach (var ev in group)
                    {
                        var cat = _categories.FirstOrDefault(c => c.Name == ev.Category);
                        <MudPaper Elevation="0" Class="pa-4"
                                  Style="@($"border-radius: 12px; border: 1px solid var(--mud-palette-divider); border-left: 4px solid {cat?.Hex}; background: #fff; cursor: pointer; transition: box-shadow 0.15s;")"
                                  @onclick="@(() => OpenEventDetail(ev))">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudStack Spacing="0" Style="min-width: 52px;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 800; font-size: 0.8rem;">
                                            @ev.Start.ToString("HH:mm")
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.68rem;">
                                            @ev.End.ToString("HH:mm")
                                        </MudText>
                                    </MudStack>
                                    <MudDivider Vertical="true" FlexItem="true" />
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@ev.Title</MudText>
                                        @if (!string.IsNullOrEmpty(ev.Description))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@ev.Description</MudText>
                                        }
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Color="@(cat?.Color ?? Color.Default)"
                                                     Variant="Variant.Text"
                                                     Style="font-size: 0.65rem; font-weight: 700; height: 18px; padding: 0 6px;">
                                                @ev.Category
                                            </MudChip>
                                            @if (!string.IsNullOrEmpty(ev.Location))
                                            {
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                                    <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Size="Size.Small"
                                                             Color="Color.Secondary" Style="font-size: 12px;" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ev.Location</MudText>
                                                </MudStack>
                                            }
                                        </MudStack>
                                    </MudStack>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    @if (ev.Attendees.Any())
                                    {
                                        <MudAvatarGroup Max="3" Spacing="2">
                                            @foreach (var a in ev.Attendees)
                                            {
                                                <MudTooltip Text="@a">
                                                    <MudAvatar Size="Size.Small" Color="Color.Primary"
                                                               Style="font-size: 0.65rem; font-weight: 700; width: 24px; height: 24px;">
                                                        @a.Substring(0, 2).ToUpper()
                                                    </MudAvatar>
                                                </MudTooltip>
                                            }
                                        </MudAvatarGroup>
                                    }
                                    <MudIconButton Icon="@Icons.Material.Outlined.ChevronRight"
                                                   Size="Size.Small" Color="Color.Inherit" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudStack>
    }

</MudContainer>