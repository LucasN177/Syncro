@page "/calendar"

<MudContainer MaxWidth="MaxWidth.False" Class="pa-6" Style="min-height: 100vh; background: #F8FAFC;">
    
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -1px;">Calendar</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @_currentMonth.ToString("MMMM yyyy") · @_events.Count(e => e.Start.Month == _currentMonth.Month) events this month
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 10px; overflow: hidden;">
                <MudButton OnClick="PrevMonth" Style="font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small" />
                </MudButton>
                <MudButton OnClick="GoToToday" Style="font-weight: 700;">Today</MudButton>
                <MudButton OnClick="NextMonth" Style="font-weight: 600;">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                </MudButton>
            </MudButtonGroup>

            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 10px; overflow: hidden;">
                @foreach (var view in new[] { "Month", "Week", "List" })
                {
                    <MudButton OnClick="@(() => _activeView = view)"
                               Style="@(_activeView == view ? "font-weight:700; background: var(--mud-palette-primary); color: #fff;" : "font-weight:600;")">
                        @view
                    </MudButton>
                }
            </MudButtonGroup>

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Size="Size.Small"
                       Style="border-radius: 10px; font-weight: 700;"
                       OnClick="OpenAddDialog">
                Add Event
            </MudButton>
        </MudStack>
    </MudStack>
    
    <MudStack Row="true" Spacing="2" Class="mb-5" Style="flex-wrap: wrap;">
        @foreach (var cat in _categories)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="@(cat.Active ? Variant.Filled : Variant.Outlined)"
                     Color="@cat.Color"
                     OnClick="@(() => ToggleCategory(cat))"
                     Style="font-weight: 600; border-radius: 8px; cursor: pointer;">
                @cat.Name (@_events.Count(e => e.Category == cat.Name))
            </MudChip>
        }
    </MudStack>
    
    @if (_activeView == "Month")
    {
        <MudPaper Elevation="0" Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); overflow: hidden; background: #fff;">
            
            <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider); background: #F8FAFC;">
                @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                {
                    <MudItem xs="0" Style="width: calc(100% / 7);">
                        <MudText Typo="Typo.caption" Align="Align.Center"
                                 Style="font-weight: 700; letter-spacing: 0.08em; padding: 12px 0; display: block; color: var(--mud-palette-text-secondary);">
                            @day
                        </MudText>
                    </MudItem>
                }
            </MudGrid>
            
            @{
                var weeks = GetCalendarWeeks();
            }
            @foreach (var week in weeks)
            {
                <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                    @foreach (var day in week)
                    {
                        var dayEvents = GetEventsForDay(day);
                        var isToday = day.Date == DateTime.Today;
                        var isCurrentMonth = day.Month == _currentMonth.Month;
                        var isSelected = _selectedDay.HasValue && _selectedDay.Value.Date == day.Date;

                        <MudItem Style="width: calc(100% / 7); min-height: 110px; border-right: 1px solid var(--mud-palette-divider); padding: 8px; cursor: pointer; transition: background 0.15s;"
                                 @onclick="@(() => SelectDay(day))">
                            
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
                                @if (isToday)
                                {
                                    <MudAvatar Size="Size.Small" Color="Color.Primary"
                                               Style="width: 26px; height: 26px; font-size: 0.75rem; font-weight: 800;">
                                        @day.Day
                                    </MudAvatar>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2"
                                             Style="@($"font-weight: {(isCurrentMonth ? "600" : "400")}; color: {(isCurrentMonth ? "inherit" : "var(--mud-palette-text-disabled)")};")">
                                        @day.Day
                                    </MudText>
                                }
                            </MudStack>
                            
                            @foreach (var ev in dayEvents.Take(3))
                            {
                                var cat = _categories.FirstOrDefault(c => c.Name == ev.Category);
                                @if (cat?.Active == true)
                                {
                                    <MudTooltip Text="@($"{ev.Title} · {ev.Start:HH:mm}")">
                                        <MudPaper Elevation="0" Class="mb-1 px-1"
                                                  Style="@($"border-radius: 4px; background: {cat.Hex}22; border-left: 3px solid {cat.Hex}; cursor: pointer;")"
                                                  @onclick="@(() => OpenEventDetail(ev))">
                                            <MudText Style="@($"font-size: 0.68rem; font-weight: 600; color: {cat.Hex}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.8;")">
                                                @ev.Title
                                            </MudText>
                                        </MudPaper>
                                    </MudTooltip>
                                }
                            }
                            @if (dayEvents.Count > 3)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                         Style="font-size: 0.65rem; font-weight: 600;">
                                    +@(dayEvents.Count - 3) more
                                </MudText>
                            }

                        </MudItem>
                    }
                </MudGrid>
            }

        </MudPaper>
    }
    
    @if (_activeView == "Week")
    {
        var weekDays = GetCurrentWeekDays();

        <MudPaper Elevation="0" Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); overflow: hidden; background: #fff;">
            
            <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider); background: #F8FAFC;">
                <MudItem Style="width: 60px; min-width: 60px;" />
                @foreach (var day in weekDays)
                {
                    var isToday = day.Date == DateTime.Today;
                    <MudItem Style="flex: 1; text-align: center; padding: 12px 4px;">
                        <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.05em; color: var(--mud-palette-text-secondary); display: block;">
                            @day.ToString("ddd").ToUpper()
                        </MudText>
                        @if (isToday)
                        {
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Style="width: 28px; height: 28px; font-size: 0.8rem; font-weight: 800; margin: 2px auto 0;">
                                @day.Day
                            </MudAvatar>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1" Style="font-weight: 700;">@day.Day</MudText>
                        }
                    </MudItem>
                }
            </MudGrid>
            
            <div style="max-height: 520px; overflow-y: auto;">
                @for (int h = 7; h <= 20; h++)
                {
                    var hour = h;
                    <MudGrid Spacing="0" Style="border-bottom: 1px solid var(--mud-palette-divider); min-height: 56px;">
                        <MudItem Style="width: 60px; min-width: 60px; padding: 6px 8px; border-right: 1px solid var(--mud-palette-divider);">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem; font-weight: 600;">
                                @($"{hour:D2}:00")
                            </MudText>
                        </MudItem>
                        @foreach (var day in weekDays)
                        {
                            var slotEvents = _events.Where(e =>
                                e.Start.Date == day.Date &&
                                e.Start.Hour == hour &&
                                (_categories.FirstOrDefault(c => c.Name == e.Category)?.Active ?? true)).ToList();

                            <MudItem Style="flex: 1; padding: 3px; border-right: 1px solid var(--mud-palette-divider); cursor: pointer;"
                                     @onclick="@(() => SelectDay(day))">
                                @foreach (var ev in slotEvents)
                                {
                                    var cat = _categories.FirstOrDefault(c => c.Name == ev.Category);
                                    <MudTooltip Text="@ev.Description">
                                        <MudPaper Elevation="0" Class="px-2 py-1 mb-1"
                                                  Style="@($"border-radius: 6px; background: {cat?.Hex}22; border-left: 3px solid {cat?.Hex}; cursor: pointer;")"
                                                  @onclick="@(() => OpenEventDetail(ev))">
                                            <MudText Style="@($"font-size: 0.68rem; font-weight: 700; color: {cat?.Hex};")">@ev.Title</MudText>
                                            <MudText Style="font-size: 0.62rem; color: var(--mud-palette-text-secondary);">@ev.Start.ToString("HH:mm")</MudText>
                                        </MudPaper>
                                    </MudTooltip>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                }
            </div>
        </MudPaper>
    }
    
    @if (_activeView == "List")
    {
        var grouped = _events
            .Where(e => e.Start >= DateTime.Today && (_categories.FirstOrDefault(c => c.Name == e.Category)?.Active ?? true))
            .OrderBy(e => e.Start)
            .GroupBy(e => e.Start.Date)
            .Take(14)
            .ToList();

        <MudStack Spacing="4">
            @foreach (var group in grouped)
            {
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (group.Key.Date == DateTime.Today)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                     Style="font-weight: 700; border-radius: 8px;">Today</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: var(--mud-palette-text-secondary);">
                                @group.Key.ToString("dddd, MMM d")
                            </MudText>
                        }
                        <MudDivider Style="flex: 1;" />
                    </MudStack>

                    @foreach (var ev in group)
                    {
                        var cat = _categories.FirstOrDefault(c => c.Name == ev.Category);
                        <MudPaper Elevation="0" Class="pa-4"
                                  Style="@($"border-radius: 12px; border: 1px solid var(--mud-palette-divider); border-left: 4px solid {cat?.Hex}; background: #fff; cursor: pointer; transition: box-shadow 0.15s;")"
                                  @onclick="@(() => OpenEventDetail(ev))">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudStack Spacing="0" Style="min-width: 52px;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 800; font-size: 0.8rem;">
                                            @ev.Start.ToString("HH:mm")
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.68rem;">
                                            @ev.End.ToString("HH:mm")
                                        </MudText>
                                    </MudStack>
                                    <MudDivider Vertical="true" FlexItem="true" />
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@ev.Title</MudText>
                                        @if (!string.IsNullOrEmpty(ev.Description))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@ev.Description</MudText>
                                        }
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudChip T="string" Size="Size.Small" Color="@(cat?.Color ?? Color.Default)"
                                                     Variant="Variant.Text"
                                                     Style="font-size: 0.65rem; font-weight: 700; height: 18px; padding: 0 6px;">
                                                @ev.Category
                                            </MudChip>
                                            @if (!string.IsNullOrEmpty(ev.Location))
                                            {
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                                    <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Size="Size.Small"
                                                             Color="Color.Secondary" Style="font-size: 12px;" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ev.Location</MudText>
                                                </MudStack>
                                            }
                                        </MudStack>
                                    </MudStack>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    @if (ev.Attendees.Any())
                                    {
                                        <MudAvatarGroup Max="3" Spacing="2">
                                            @foreach (var a in ev.Attendees)
                                            {
                                                <MudTooltip Text="@a">
                                                    <MudAvatar Size="Size.Small" Color="Color.Primary"
                                                               Style="font-size: 0.65rem; font-weight: 700; width: 24px; height: 24px;">
                                                        @a.Substring(0, 2).ToUpper()
                                                    </MudAvatar>
                                                </MudTooltip>
                                            }
                                        </MudAvatarGroup>
                                    }
                                    <MudIconButton Icon="@Icons.Material.Outlined.ChevronRight"
                                                   Size="Size.Small" Color="Color.Inherit" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudStack>
    }

</MudContainer>

<MudDialog @bind-IsVisible="_detailOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true })">
    <TitleContent>
        @if (_selectedEvent != null)
        {
            var cat = _categories.FirstOrDefault(c => c.Name == _selectedEvent.Category);
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Circle" Style="@($"color: {cat?.Hex}; font-size: 14px;")" />
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@_selectedEvent.Title</MudText>
            </MudStack>
        }
    </TitleContent>
    <DialogContent>
        @if (_selectedEvent != null)
        {
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Schedule" Color="Color.Secondary" Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        @_selectedEvent.Start.ToString("dddd, MMMM d · HH:mm") – @_selectedEvent.End.ToString("HH:mm")
                    </MudText>
                </MudStack>
                @if (!string.IsNullOrEmpty(_selectedEvent.Location))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Color="Color.Secondary" Size="Size.Small" />
                        <MudText Typo="Typo.body2">@_selectedEvent.Location</MudText>
                    </MudStack>
                }
                @if (!string.IsNullOrEmpty(_selectedEvent.Description))
                {
                    <MudStack Row="true" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Outlined.Notes" Color="Color.Secondary" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedEvent.Description</MudText>
                    </MudStack>
                }
                @if (_selectedEvent.Attendees.Any())
                {
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Outlined.Group" Color="Color.Secondary" Size="Size.Small" />
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">Attendees</MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap; padding-left: 28px;">
                            @foreach (var a in _selectedEvent.Attendees)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                         Avatar="@a.Substring(0,2).ToUpper()"
                                         Style="font-size: 0.72rem; border-radius: 8px;">
                                    @a
                                </MudChip>
                            }
                        </MudStack>
                    </MudStack>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Error" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.Delete"
                   OnClick="@(() => { _events.Remove(_selectedEvent!); _detailOpen = false; })">
            Delete
        </MudButton>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Style="border-radius: 8px; font-weight: 700;"
                   OnClick="@(() => _detailOpen = false)">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-IsVisible="_addOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 700;">New Event</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_newEvent.Title" Label="Title" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Title"
                          Style="border-radius: 10px;" />
            <MudTextField @bind-Value="_newEvent.Description" Label="Description" Variant="Variant.Outlined"
                          Lines="2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Notes" />
            <MudTextField @bind-Value="_newEvent.Location" Label="Location" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.LocationOn" />
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_newStartDate" Label="Start date" Variant="Variant.Outlined"
                                   DateFormat="dd.MM.yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker @bind-Time="_newStartTime" Label="Start time" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_newEndDate" Label="End date" Variant="Variant.Outlined"
                                   DateFormat="dd.MM.yyyy" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker @bind-Time="_newEndTime" Label="End time" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <MudSelect T="string" @bind-Value="_newEvent.Category" Label="Category" Variant="Variant.Outlined"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Label">
                @foreach (var cat in _categories)
                {
                    <MudSelectItem Value="@cat.Name">@cat.Name</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => _addOpen = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Style="border-radius: 8px; font-weight: 700;"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="SaveNewEvent">
            Save Event
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    // ── Temporäre lokale Models (später durch eigene ersetzen) ───────────────

    private class CalendarEvent
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Location { get; set; } = "";
        public string Category { get; set; } = "Meeting";
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public List<string> Attendees { get; set; } = new();
    }

    private class CategoryFilter
    {
        public string Name { get; set; } = "";
        public Color Color { get; set; }
        public string Hex { get; set; } = "#6366F1";
        public bool Active { get; set; } = true;
    }

    // ── State ────────────────────────────────────────────────────────────────

    private DateTime _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _selectedDay;
    private string _activeView = "Month";
    private bool _detailOpen;
    private bool _addOpen;
    private CalendarEvent? _selectedEvent;
    private CalendarEvent _newEvent = new();
    private DateTime? _newStartDate = DateTime.Today;
    private DateTime? _newEndDate = DateTime.Today;
    private TimeSpan? _newStartTime = new TimeSpan(9, 0, 0);
    private TimeSpan? _newEndTime = new TimeSpan(10, 0, 0);

    private List<CategoryFilter> _categories = new()
    {
        new() { Name = "Meeting",  Color = Color.Primary,   Hex = "#6366F1" },
        new() { Name = "Review",   Color = Color.Warning,   Hex = "#F59E0B" },
        new() { Name = "Release",  Color = Color.Success,   Hex = "#10B981" },
        new() { Name = "Personal", Color = Color.Secondary, Hex = "#8B5CF6" },
        new() { Name = "Deadline", Color = Color.Error,     Hex = "#EF4444" },
    };

    private List<CalendarEvent> _events = new()
    {
        new() { Title = "Sprint Planning",       Category = "Meeting",  Start = DateTime.Today.AddDays(0).Date.AddHours(9),  End = DateTime.Today.AddDays(0).Date.AddHours(10),  Location = "Room A", Attendees = new() { "Lucas M.", "Anna K.", "Tim R." }, Description = "Sprint 5 kick-off planning session." },
        new() { Title = "Design Review",         Category = "Review",   Start = DateTime.Today.AddDays(1).Date.AddHours(14), End = DateTime.Today.AddDays(1).Date.AddHours(15),  Location = "Zoom",   Attendees = new() { "Sara B.", "Anna K." },             Description = "Review new onboarding screens." },
        new() { Title = "v2.0 Release",          Category = "Release",  Start = DateTime.Today.AddDays(3).Date.AddHours(10), End = DateTime.Today.AddDays(3).Date.AddHours(11),  Location = "",       Attendees = new() { "Lucas M.", "Tim R." },              Description = "Production release of v2.0." },
        new() { Title = "1:1 with Anna",         Category = "Meeting",  Start = DateTime.Today.AddDays(2).Date.AddHours(11), End = DateTime.Today.AddDays(2).Date.AddHours(12),  Location = "Office", Attendees = new() { "Anna K." },                        Description = "" },
        new() { Title = "API Deadline",          Category = "Deadline", Start = DateTime.Today.AddDays(5).Date.AddHours(18), End = DateTime.Today.AddDays(5).Date.AddHours(18),  Location = "",       Attendees = new(),                                      Description = "Public API documentation must be finalized." },
        new() { Title = "Team Retrospective",    Category = "Meeting",  Start = DateTime.Today.AddDays(7).Date.AddHours(15), End = DateTime.Today.AddDays(7).Date.AddHours(16),  Location = "Room B", Attendees = new() { "Lucas M.", "Anna K.", "Tim R.", "Sara B." }, Description = "" },
        new() { Title = "Doctor Appointment",    Category = "Personal", Start = DateTime.Today.AddDays(4).Date.AddHours(8),  End = DateTime.Today.AddDays(4).Date.AddHours(9),   Location = "City Center", Attendees = new(),                               Description = "" },
        new() { Title = "Code Review Session",   Category = "Review",   Start = DateTime.Today.AddDays(6).Date.AddHours(10), End = DateTime.Today.AddDays(6).Date.AddHours(11),  Location = "Zoom",   Attendees = new() { "Tim R.", "Lucas M." },              Description = "Review EF Core migration PR." },
        new() { Title = "Stakeholder Demo",      Category = "Meeting",  Start = DateTime.Today.AddDays(9).Date.AddHours(13), End = DateTime.Today.AddDays(9).Date.AddHours(14),  Location = "Boardroom", Attendees = new() { "Lucas M.", "Anna K." },          Description = "Demo of sprint results to stakeholders." },
        new() { Title = "Hotfix Deadline",       Category = "Deadline", Start = DateTime.Today.AddDays(2).Date.AddHours(17), End = DateTime.Today.AddDays(2).Date.AddHours(17),  Location = "",       Attendees = new(),                                      Description = "Auth hotfix must be deployed." },
        new() { Title = "Gym",                   Category = "Personal", Start = DateTime.Today.AddDays(1).Date.AddHours(7),  End = DateTime.Today.AddDays(1).Date.AddHours(8),   Location = "FitX",   Attendees = new(),                                      Description = "" },
        new() { Title = "Architecture Review",   Category = "Review",   Start = DateTime.Today.AddDays(10).Date.AddHours(9),End = DateTime.Today.AddDays(10).Date.AddHours(11),  Location = "Room A", Attendees = new() { "Lucas M.", "Tim R.", "Sara B." },   Description = "Review new microservice boundaries." },
    };

    // ── Navigation ───────────────────────────────────────────────────────────

    private void PrevMonth() => _currentMonth = _currentMonth.AddMonths(-1);
    private void NextMonth() => _currentMonth = _currentMonth.AddMonths(1);
    private void GoToToday()  { _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1); _selectedDay = DateTime.Today; }
    private void SelectDay(DateTime day) => _selectedDay = day;
    private void ToggleCategory(CategoryFilter cat) => cat.Active = !cat.Active;

    // ── Dialogs ──────────────────────────────────────────────────────────────

    private void OpenEventDetail(CalendarEvent ev) { _selectedEvent = ev; _detailOpen = true; }

    private void OpenAddDialog()
    {
        _newEvent = new CalendarEvent { Category = "Meeting" };
        _newStartDate = _selectedDay ?? DateTime.Today;
        _newEndDate   = _selectedDay ?? DateTime.Today;
        _newStartTime = new TimeSpan(9, 0, 0);
        _newEndTime   = new TimeSpan(10, 0, 0);
        _addOpen = true;
    }

    private void SaveNewEvent()
    {
        if (string.IsNullOrWhiteSpace(_newEvent.Title)) return;
        _newEvent.Start = (_newStartDate ?? DateTime.Today).Date + (_newStartTime ?? TimeSpan.Zero);
        _newEvent.End   = (_newEndDate   ?? DateTime.Today).Date + (_newEndTime   ?? TimeSpan.Zero);
        _events.Add(_newEvent);
        _addOpen = false;
    }

    // ── Calendar Helpers ─────────────────────────────────────────────────────

    private List<List<DateTime>> GetCalendarWeeks()
    {
        var weeks = new List<List<DateTime>>();
        var first = _currentMonth;
        var offset = ((int)first.DayOfWeek + 6) % 7; // Monday = 0
        var start = first.AddDays(-offset);

        for (int w = 0; w < 6; w++)
        {
            var week = Enumerable.Range(0, 7).Select(d => start.AddDays(w * 7 + d)).ToList();
            if (week.Any(d => d.Month == _currentMonth.Month))
                weeks.Add(week);
        }
        return weeks;
    }

    private List<CalendarEvent> GetEventsForDay(DateTime day) =>
        _events.Where(e => e.Start.Date == day.Date).OrderBy(e => e.Start).ToList();

    private List<DateTime> GetCurrentWeekDays()
    {
        var today = _selectedDay ?? DateTime.Today;
        var offset = ((int)today.DayOfWeek + 6) % 7;
        var monday = today.AddDays(-offset);
        return Enumerable.Range(0, 7).Select(d => monday.AddDays(d)).ToList();
    }
}